{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Integrations": {
    "Defaults": {
      "MaxRetryAttempts": 5,
      "DelaySeconds": 1,
      "TimeoutSeconds": 2,
      "CircuitBreakAfterFailures": 5,
      "DegradedResponseThresholdSeconds": 2
    },
    "Services": [
      { "ServiceName": "A", "BaseUrl": "http://localhost:5001" },
      { "ServiceName": "B", "BaseUrl": "http://localhost:5002" },
      { "ServiceName": "C", "BaseUrl": "http://localhost:5003" }
    ]
  },
  "HealthChecksUI": {
    "HealthChecks": [
      { "Name": "Resilience Monitor", "Uri": "http://localhost:5295/health" }
    ],
    "EvaluationTimeInSeconds": 5
  }
}