{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Integrations": {
    "Defaults": {
      "MaxRetryAttempts": 5,
      "DelaySeconds": 1,
      "TimeoutSeconds": 2,
      "CircuitBreakAfterFailures": 5,
      "DegradedResponseThresholdSeconds": 2,
      "Chaos": {
        "FaultEnabled": false,
        "FaultInjectionRate": 0.0,
        "LatencyEnabled": false,
        "LatencyInjectionRate": 0.0,
        "LatencySeconds": 0
      }
    },
    "Services": [
      {
        "ServiceName": "Healthy",
        "BaseUrl": "http://localhost:5001",
        "Chaos": {
          "FaultEnabled": true,
          "FaultInjectionRate": 1.0,
          "LatencyEnabled": false,
          "LatencyInjectionRate": 0.0,
          "LatencySeconds": 0
        }
      },
      {
        "ServiceName": "Faulty",
        "BaseUrl": "http://localhost:5002"
      },
      {
        "ServiceName": "Slow",
        "BaseUrl": "http://localhost:5003"
      },
      {
        "ServiceName": "Down",
        "BaseUrl": "http://localhost:5004"
      }
    ]
  },
  "HealthChecksUI": {
    "HealthChecks": [
      {
        "Name": "Resilience Monitor",
        "Uri": "http://localhost:5295/health"
      },
      {
        "Name": "Chaos Monitor",
        "Uri": "http://localhost:5295/query"
      }
    ],
    "EvaluationTimeInSeconds": 5
  }
}