{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Integrations": {
    "Defaults": {
      "MaxRetryAttempts": 2,
      "DelaySeconds": 1,
      "TimeoutSeconds": 2,
      "CircuitBreakAfterFailures": 5,
      "DegradedResponseThresholdSeconds": 2,
      "Chaos": {
        "FaultEnabled": false,
        "FaultInjectionRate": 0.0,
        "LatencyEnabled": false,
        "LatencyInjectionRate": 0.0,
        "LatencySeconds": 0
      }
    },
    "Services": [
      {
        "ServiceName": "Healthy",
        "BaseUrl": "http://localhost:5001"
      },
      {
        "ServiceName": "Faulty",
        "BaseUrl": "http://localhost:5002",
        "Chaos": {
          "FaultEnabled": true,
          "FaultInjectionRate": 0.4
        }
      },
      {
        "ServiceName": "Slow",
        "BaseUrl": "http://localhost:5003",
        "Chaos": {
          "LatencyEnabled": true,
          "LatencyInjectionRate": 0.6,
          "LatencySeconds": 3
        }
      },
      {
        "ServiceName": "Down",
        "BaseUrl": "http://localhost:5004",
        "Chaos": {
          "FaultEnabled": true,
          "FaultInjectionRate": 1.0
        }
      }
    ]
  },
  "HealthChecksUI": {
    "HealthChecks": [
      { "Name": "Healthy", "Uri": "http://localhost:5295/health/healthy" },
      { "Name": "Faulty",  "Uri": "http://localhost:5295/health/faulty" },
      { "Name": "Slow",    "Uri": "http://localhost:5295/health/slow" },
      { "Name": "Down",    "Uri": "http://localhost:5295/health/down" }
    ],
    "EvaluationTimeInSeconds": 5
  }
}