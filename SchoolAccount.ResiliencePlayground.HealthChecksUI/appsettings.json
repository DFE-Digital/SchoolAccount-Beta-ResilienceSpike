{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Integrations": {
    "Defaults": {
      "MaxRetryAttempts": 5,
      "DelaySeconds": 1,
      "TimeoutSeconds": 2,
      "CircuitBreakAfterFailures": 5,
      "DegradedResponseThresholdSeconds": 2,
      "Chaos": {
        "LatencyEnabled": false,
        "LatencyInjectionRate": 0.0,
        "LatencySeconds": 0,
        "FaultEnabled": false,
        "FaultInjectionRate": 0.0
      }
    },
    "Services": [
      {
        "ServiceName": "A",
        "BaseUrl": "http://localhost:5001",
        "Chaos": {
          "FaultEnabled": true,
          "FaultInjectionRate": 0.4,
          "LatencyEnabled": true,
          "LatencyInjectionRate": 0.15,
          "LatencySeconds": 3
        }
      },
      {
        "ServiceName": "B",
        "BaseUrl": "http://localhost:5002"
      },
      {
        "ServiceName": "C",
        "BaseUrl": "http://localhost:5003"
      }
    ]
  },
  "HealthChecksUI": {
    "HealthChecks": [
      {
        "Name": "Resilience Monitor",
        "Uri": "http://localhost:5295/health"
      }
    ],
    "EvaluationTimeInSeconds": 5
  }
}